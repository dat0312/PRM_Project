@page "/login"
@model Web_App.Pages.LoginModel
@{
    Layout = null; // Tắt Layout mặc định để trang Login đứng độc lập giống Flutter
    ViewData["Title"] = "Đăng nhập - MyFSchool";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Font giống Flutter mặc định hoặc Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Icon FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-color: #F27024;
            --primary-color-light: rgba(242, 112, 36, 0.1);
            --bg-color-web: rgba(242, 112, 36, 0.05);
            --text-color: #333;
            --text-muted: #757575;
            --border-color: #E0E0E0;
            --input-bg: #FAFAFA;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color-web);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .login-container {
            background-color: #fff;
            width: 100%;
            max-width: 450px;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.05);
            box-sizing: border-box;
        }

        .logo-container {
            display: flex;
            justify-content: center;
            margin-bottom: 24px;
        }

        .logo-icon {
            width: 60px;
            height: 60px;
            background-color: var(--primary-color-light);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--primary-color);
            font-size: 28px;
        }

        .title {
            text-align: center;
            font-size: 32px;
            font-weight: 700;
            color: var(--primary-color);
            margin: 0 0 8px 0;
            letter-spacing: -0.5px;
        }

        .subtitle {
            text-align: center;
            font-size: 16px;
            color: var(--text-muted);
            margin: 0 0 40px 0;
        }

        .form-group {
            margin-bottom: 20px;
            position: relative;
        }

        .form-group:last-of-type {
            margin-bottom: 12px;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 16px;
        }

        .form-control {
            width: 100%;
            padding: 16px 16px 16px 48px;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            background-color: var(--input-bg);
            font-size: 16px;
            font-family: inherit;
            box-sizing: border-box;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 2px var(--primary-color-light);
        }

        .forgot-password {
            text-align: right;
            margin-bottom: 24px;
        }

        .forgot-password a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
        }

        .btn-login {
            width: 100%;
            padding: 16px;
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: background-color 0.3s ease;
            font-family: inherit;
        }

        .btn-login:hover {
            background-color: #d95e1a;
        }

        .footer-text {
            text-align: center;
            margin-top: 48px;
            font-size: 12px;
            color: #9e9e9e;
        }

        /* Responsive như trong Flutter */
        @@media (max-width: 800px) {
            body {
                background-color: #fff;
                align-items: flex-start;
            }

            .login-container {
                box-shadow: none;
                border-radius: 0;
                padding: 40px 24px;
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="logo-container">
            <!-- Thay logo ảnh bằng icon tương tự -->
            <div class="logo-icon">
                <i class="fa-solid fa-graduation-cap"></i>
            </div>
        </div>
        
        <h1 class="title">MyFSchool</h1>
        <p class="subtitle">Hệ thống quản lý giáo dục</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div style="color: red; text-align: center; margin-bottom: 16px; font-size: 14px; background-color: #ffebee; padding: 10px; border-radius: 8px;">
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="form-group">
                <i class="fa-solid fa-phone input-icon"></i>
                <input type="tel" asp-for="Phone" class="form-control" placeholder="Số điện thoại" required autofocus />
            </div>

            <div class="form-group">
                <i class="fa-solid fa-lock input-icon"></i>
                <input type="password" asp-for="Password" class="form-control" placeholder="Mật khẩu" required />
            </div>

            <div class="forgot-password">
                <a href="/forgot-password">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-login">Đăng nhập</button>
        </form>

        <div class="footer-text">
            © 2026 FPT Schools • Phiên bản 1.0.0
        </div>
    </div>
</body>
</html>
