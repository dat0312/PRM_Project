@page
@model Web_App.Pages.Admin.Clubs.IndexModel
@{
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold" style="color: #D65B1A;">Quản lý Câu lạc bộ</h2>
        <p class="text-muted mb-0">Theo dõi và điều phối các hoạt động ngoại khóa học đường.</p>
    </div>
    <a href="/Admin/Clubs/Add" class="btn text-white px-4 py-2" style="background-color: #F27024; border-radius: 8px; font-weight: 600;">
        <i class="fa-solid fa-plus me-2"></i> Thành lập CLB mới
    </a>
</div>

<!-- Stats -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm" style="border-radius: 12px; border: 1px solid #E0E0E0 !important;">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 48px; height: 48px; background-color: #FFF0E6; color: #D65B1A;">
                    <i class="fa-solid fa-star fs-4"></i>
                </div>
                <div class="ms-3">
                    <p class="text-muted mb-1" style="font-size: 13px;">Tổng số CLB</p>
                    <h4 class="mb-0 fw-bold text-dark">@(Model.Stats?.TotalClubs ?? 0)</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Table Card -->
<div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; border: 1px solid #E0E0E0 !important;">
    <div class="card-header bg-white border-bottom p-4">
        <form method="get" class="row align-items-end">
            <div class="col-md-4">
                <label class="form-label text-muted fw-bold" style="font-size: 12px;">Tìm tên câu lạc bộ</label>
                <input type="text" class="form-control" name="SearchQuery" value="@Model.SearchQuery" placeholder="Ví dụ: CLB Âm nhạc" style="border-radius: 8px;">
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted fw-bold" style="font-size: 12px;">Loại hình</label>
                <select class="form-select" name="SelectedType" style="border-radius: 8px;">
                    <option value="Tất cả các loại" selected="@(Model.SelectedType == "Tất cả các loại")">Tất cả các loại</option>
                    <option value="Nghệ thuật & Văn hóa" selected="@(Model.SelectedType == "Nghệ thuật & Văn hóa")">Nghệ thuật & Văn hóa</option>
                    <option value="Thể thao" selected="@(Model.SelectedType == "Thể thao")">Thể thao</option>
                    <option value="Học thuật" selected="@(Model.SelectedType == "Học thuật")">Học thuật</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted fw-bold" style="font-size: 12px;">Trạng thái</label>
                <select class="form-select" name="SelectedStatus" style="border-radius: 8px;">
                    <option value="Tất cả trạng thái" selected="@(Model.SelectedStatus == "Tất cả trạng thái")">Tất cả trạng thái</option>
                    <option value="HOẠT ĐỘNG" selected="@(Model.SelectedStatus == "HOẠT ĐỘNG")">HOẠT ĐỘNG</option>
                    <option value="TẠM NGỪNG" selected="@(Model.SelectedStatus == "TẠM NGỪNG")">TẠM NGỪNG</option>
                </select>
            </div>
            <div class="col-md-2 d-flex">
                <button type="submit" class="btn btn-light w-100" style="border-radius: 8px; background-color: #F3F3F3; border: none; font-weight: 500;">
                    <i class="fa-solid fa-filter me-2 text-muted"></i> Lọc
                </button>
            </div>
        </form>
    </div>

    <!-- Table Header -->
    <div class="p-3" style="background-color: #F9F9F9; border-bottom: 2px solid #F27024;">
        <div class="row text-muted fw-bold" style="font-size: 12px;">
            <div class="col-3">TÊN CÂU LẠC BỘ</div>
            <div class="col-3">CHỦ NHIỆM</div>
            <div class="col-2">THÀNH VIÊN</div>
            <div class="col-2">TRẠNG THÁI</div>
            <div class="col-2">HÀNH ĐỘNG</div>
        </div>
    </div>

    <!-- Table Body -->
    <div class="list-group list-group-flush">
        @foreach (var club in Model.Clubs)
        {
            var isActive = club.Status == "HOẠT ĐỘNG";
            var statusBg = isActive ? "#E8F5E9" : "#FFF8E1";
            var statusColor = isActive ? "#2E7D32" : "#F57F17";

            <div class="list-group-item p-3 border-bottom">
                <div class="row align-items-center">
                    <div class="col-3">
                        <p class="mb-0 fw-bold" style="font-size: 14px;">@club.Name (@club.Code)</p>
                        <p class="text-muted mb-0" style="font-size: 12px;">@club.Type</p>
                    </div>
                    <div class="col-3 d-flex align-items-center">
                        <div class="rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 28px; height: 28px; background-color: #E0E0E0; font-size: 10px; font-weight: bold; color: #555;">
                            @(string.IsNullOrEmpty(club.PresidentName) ? "??" : club.PresidentName.Substring(0, Math.Min(2, club.PresidentName.Length)).ToUpper())
                        </div>
                        <span style="font-size: 14px;">@(club.PresidentName ?? "Chưa cập nhật")</span>
                    </div>
                    <div class="col-2">
                        <span class="badge" style="background-color: #F27024; border-radius: 12px;">@club.MemberCount thành viên</span>
                    </div>
                    <div class="col-2">
                        <span class="badge" style="background-color: @statusBg; color: @statusColor; border-radius: 4px;">@club.Status</span>
                    </div>
                    <div class="col-2">
                        <button class="btn btn-sm btn-link text-primary p-0 me-2" title="Quản lý thành viên" onclick="manageMembers(@club.Id, '@club.Name')">
                            <i class="fa-solid fa-users fs-5"></i>
                        </button>
                        <a href="/Admin/Clubs/Add?id=@club.Id" class="btn btn-sm btn-link text-warning p-0 me-2" title="Sửa CLB">
                            <i class="fa-solid fa-edit fs-5"></i>
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@club.Id" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn câu lạc bộ này không?');">
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Xóa CLB">
                                <i class="fa-solid fa-trash fs-5"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
        @if (!Model.Clubs.Any())
        {
            <div class="p-4 text-center text-muted">
                Không tìm thấy câu lạc bộ nào.
            </div>
        }
    </div>
</div>

<!-- Proposals Section -->
<div class="card border-0 shadow-sm" style="border-radius: 12px; border: 1px solid #E0E0E0 !important;">
    <div class="card-header bg-white border-bottom p-3">
        <h6 class="mb-0 fw-bold" style="color: #D65B1A;">Đơn yêu cầu chờ xử lý</h6>
    </div>
    <div class="list-group list-group-flush">
        @foreach (var proposal in Model.Proposals)
        {
            <div class="list-group-item p-3 border-bottom">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <div class="rounded p-2" style="background-color: #FFF0E6; color: #D65B1A;">
                            <i class="fa-solid fa-file-alt"></i>
                        </div>
                    </div>
                    <div class="col">
                        <h6 class="fw-bold mb-1">@proposal.Title</h6>
                        <p class="text-muted mb-0" style="font-size: 12px;">Người gửi: @proposal.SenderName (@proposal.SenderCode) &bull; Ngày: @proposal.Date</p>
                    </div>
                    <div class="col-auto">
                        <span class="badge border border-warning text-warning" style="background-color: #FFF8E1;">@proposal.Status</span>
                    </div>
                    <div class="col-auto ms-3">
                        <form method="post" asp-page-handler="RejectProposal" asp-route-id="@proposal.Id" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm px-3">Từ chối</button>
                        </form>
                        <form method="post" asp-page-handler="ApproveProposal" asp-route-id="@proposal.Id" class="d-inline ms-1">
                            <button type="submit" class="btn btn-success btn-sm px-3">Duyệt</button>
                        </form>
                    </div>
                </div>
            </div>
        }
        @if (!Model.Proposals.Any())
        {
            <div class="p-3 text-center text-muted">
                Không có đơn yêu cầu nào đang chờ duyệt.
            </div>
        }
    </div>
</div>

<!-- Members Modal Placeholder -->
<div class="modal fade" id="membersModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="membersModalTitle">Thành viên</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex mb-3">
            <input type="number" id="newMemberId" class="form-control me-2" placeholder="Nhập ID Người dùng (VD: 6)">
            <button class="btn btn-primary" onclick="addMember()">Thêm</button>
        </div>
        <div id="membersList" class="list-group">
            <!-- Members will be loaded here via JS -->
            <div class="text-center p-3 text-muted">Đang tải...</div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        const baseUrl = '@Model.BackendApiUrl';
        let currentClubId = 0;

        function manageMembers(clubId, clubName) {
            currentClubId = clubId;
            document.getElementById('membersModalTitle').innerText = 'Thành viên: ' + clubName;
            
            var modal = new bootstrap.Modal(document.getElementById('membersModal'));
            modal.show();

            loadMembers();
        }

        async function loadMembers() {
            const listDiv = document.getElementById('membersList');
            listDiv.innerHTML = '<div class="text-center p-3 text-muted">Đang tải...</div>';
            
            try {
                const response = await fetch(`${baseUrl}/api/club/${currentClubId}/members`);
                if (response.ok) {
                    const members = await response.json();
                    if (members.length === 0) {
                        listDiv.innerHTML = '<div class="text-center p-3 text-muted">Chưa có thành viên nào</div>';
                    } else {
                        listDiv.innerHTML = members.map(m => `
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-light d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                        <i class="fa-solid fa-person text-secondary"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">${m.name || 'Người dùng'}</h6>
                                        <small class="text-muted">ID: ${m.userId} - ${m.email || ''}</small>
                                    </div>
                                </div>
                                <button class="btn btn-link text-danger" onclick="removeMember(${m.userId})">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        `).join('');
                    }
                } else {
                    listDiv.innerHTML = '<div class="text-center p-3 text-danger">Lỗi khi tải danh sách</div>';
                }
            } catch (error) {
                listDiv.innerHTML = '<div class="text-center p-3 text-danger">Lỗi kết nối</div>';
            }
        }

        async function addMember() {
            const input = document.getElementById('newMemberId');
            const userId = input.value;
            if (!userId) return;

            try {
                const response = await fetch(`${baseUrl}/api/club/${currentClubId}/add-member`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId: parseInt(userId) })
                });
                
                if (response.ok) {
                    input.value = '';
                    loadMembers();
                    // Optionally trigger a page reload after closing to update member count
                } else {
                    alert('Thêm thất bại');
                }
            } catch (error) {
                alert('Lỗi kết nối');
            }
        }

        async function removeMember(userId) {
            if (!confirm('Bạn có chắc chắn muốn xóa thành viên này?')) return;

            try {
                const response = await fetch(`${baseUrl}/api/club/${currentClubId}/remove-member/${userId}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    loadMembers();
                } else {
                    alert('Xóa thất bại');
                }
            } catch (error) {
                alert('Lỗi kết nối');
            }
        }
    </script>
}
