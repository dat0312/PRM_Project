    }

    function toggleAccordion(headerEl) {
        const content = headerEl.nextElementSibling;
        const icon = headerEl.querySelector('i');
        
        if (content.classList.contains('active')) {
            content.classList.remove('active');
            icon.className = 'fas fa-chevron-down';
        } else {
            // Close others
            document.querySelectorAll('.accordion-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.accordion-header i').forEach(el => el.className = 'fas fa-chevron-down');
            
            content.classList.add('active');
            icon.className = 'fas fa-chevron-up';
        }
    }

    function closeEditScreen() {
        document.getElementById('mainContainer').style.display = 'block';
        document.getElementById('editContainer').style.display = 'none';
        currentEditingClassId = null;
        currentEditingStudentId = null;
    }

    async function saveGrades() {
        const rows = document.querySelectorAll('#subjectsAccordion tbody tr');
        let payload = [];
        const year = document.getElementById('filterYear').value || "2025-2026";

        rows.forEach(row => {
            const subjectId = parseInt(row.getAttribute('data-subject'));
            const semester = parseInt(row.getAttribute('data-semester'));
            
            const getVal = (name) => {
                let val = row.querySelector(`input[name="${name}"]`).value;
                return val === '' ? null : parseFloat(val);
            };

            let gradeData = {
                studentId: currentEditingStudentId,
                subjectId: subjectId,
                classId: currentEditingClassId,
                academicYear: year,
                semester: semester,
                attendanceScore: getVal('attendanceScore'),
                oralScore1: getVal('oralScore1'),
                oralScore2: getVal('oralScore2'),
                fifteenMinScore1: getVal('fifteenMinScore1'),
                fifteenMinScore2: getVal('fifteenMinScore2'),
                midtermScore: getVal('midtermScore'),
                finalScore: getVal('finalScore')
            };

            // Only add to payload if at least one score is filled
            if (gradeData.attendanceScore != null || gradeData.oralScore1 != null || gradeData.oralScore2 != null || 
                gradeData.fifteenMinScore1 != null || gradeData.fifteenMinScore2 != null || 
                gradeData.midtermScore != null || gradeData.finalScore != null) {
                payload.push(gradeData);
            }
        });

        if (payload.length === 0) {
            alert("Vui lòng nhập ít nhất một điểm trước khi lưu!");
            return;
        }

        try {
            const res = await fetch(`/api/web/grades/student/${currentEditingStudentId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (res.ok) {
                alert("Lưu điểm thành công!");
                await loadData();
                closeEditScreen();
            } else {
                const msg = await res.text();
                alert("Lỗi lưu điểm: " + msg);
            }
        } catch (e) {
            alert("Lỗi kết nối");
        }
    }
</script>
