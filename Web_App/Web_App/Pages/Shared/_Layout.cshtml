@using System.Security.Claims
@{
    var activeMenu = ViewData["ActiveMenu"] as string ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? "Người dùng";
    var email = User.FindFirst("UserEmail")?.Value ?? "Chưa cập nhật";
    var phone = User.FindFirst("UserPhone")?.Value ?? "Chưa cập nhật";
    var roles = User.FindAll(ClaimTypes.Role).Select(r => r.Value).ToList();
    var roleDisplay = roles.Contains("Admin") ? "Quản trị viên" : (roles.Contains("Teacher") ? "Giáo viên" : "Học sinh");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyFSchool</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        :root {
            --primary-color: #F27024;
            --bg-color: #F9F9F9;
            --sidebar-width: 256px;
            --topbar-height: 64px;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--primary-color);
            color: white;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 24px;
            display: flex;
            align-items: center;
        }

        .sidebar-logo {
            background-color: white;
            border-radius: 4px;
            padding: 4px;
            width: 32px;
            height: 32px;
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--primary-color);
        }

        .sidebar-title {
            font-size: 20px;
            font-weight: 700;
            margin-left: 16px;
        }

        .menu-list {
            list-style: none;
            padding: 0;
            margin: 32px 0 0 0;
        }

        .menu-item {
            margin: 4px 16px;
            border-radius: 4px;
            transition: all 0.2s;
        }

        .menu-item a {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: white;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
        }

        .menu-item i {
            width: 24px;
            font-size: 16px;
            margin-right: 12px;
        }

        .menu-item.active {
            background-color: rgba(255, 255, 255, 0.2);
            border-left: 4px solid white;
        }

        .sidebar-bottom {
            margin-top: auto;
            padding: 24px;
        }

        .btn-notification {
            background-color: white;
            color: #A04100;
            padding: 12px 16px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            text-decoration: none;
            font-weight: bold;
            margin-bottom: 16px;
        }

        .btn-logout {
            color: white;
            display: flex;
            align-items: center;
            text-decoration: none;
            font-weight: 600;
            padding: 8px 16px;
        }

        .btn-logout i {
            margin-right: 16px;
        }

        /* Main Content */
        .main-wrapper {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Topbar */
        .topbar {
            height: var(--topbar-height);
            background-color: white;
            border-bottom: 1px solid #E2E2E2;
            display: flex;
            align-items: center;
            padding: 0 24px;
            justify-content: flex-end;
            flex-shrink: 0;
        }

        .topbar-divider {
            width: 1px;
            height: 32px;
            background-color: #E2E2E2;
            margin: 0 16px;
        }

        .user-info {
            text-align: right;
            margin-right: 12px;
        }

        .user-name {
            font-weight: 700;
            font-size: 14px;
            color: #333;
            margin: 0;
        }

        .user-role {
            font-size: 11px;
            color: #888;
            margin: 0;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background-color: var(--primary-color);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            font-size: 18px;
        }

        /* Content Body */
        .content-body {
            flex-grow: 1;
            overflow-y: auto;
            padding: 24px;
        }

        @@media (max-width: 800px) {
            .sidebar {
                display: none; /* Trên mobile sẽ làm dạng hamburger sau nếu cần */
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <i class="fa-solid fa-graduation-cap"></i>
            </div>
            <div class="sidebar-title">MyFSchool</div>
        </div>

        <ul class="menu-list">
            @if (roles.Contains("Admin"))
            {
                <li class="menu-item @(activeMenu == "Users" ? "active" : "")">
                    <a href="/Admin/Users"><i class="fa-solid fa-users"></i> Quản lý người dùng</a>
                </li>
                <li class="menu-item @(activeMenu == "Schedules" ? "active" : "")">
                    <a href="/Admin/Schedules"><i class="fa-solid fa-calendar-alt"></i> Lịch học</a>
                </li>
                <li class="menu-item @(activeMenu == "Grades" ? "active" : "")">
                    <a href="/Admin/Grades"><i class="fa-solid fa-star"></i> Điểm số</a>
                </li>
                <li class="menu-item @(activeMenu == "Requests" ? "active" : "")">
                    <a href="/Admin/Requests"><i class="fa-solid fa-file-alt"></i> Đơn từ</a>
                </li>
                <li class="menu-item @(activeMenu == "Clubs" ? "active" : "")">
                    <a href="/Admin/Clubs"><i class="fa-solid fa-basketball-ball"></i> Câu lạc bộ</a>
                </li>
            }
            @if (roles.Contains("Teacher"))
            {
                <li class="menu-item @(activeMenu == "Schedule" ? "active" : "")">
                    <a href="/Teacher/Schedule"><i class="fa-solid fa-calendar-alt"></i> Lịch dạy</a>
                </li>
                <li class="menu-item @(activeMenu == "Grades" ? "active" : "")">
                    <a href="/Teacher/Grades"><i class="fa-solid fa-star"></i> Điểm số</a>
                </li>
                <li class="menu-item @(activeMenu == "ClassManagement" ? "active" : "")">
                    <a href="/Teacher/ClassManagement"><i class="fa-solid fa-users"></i> Quản lý lớp</a>
                </li>
                <li class="menu-item @(activeMenu == "Requests" ? "active" : "")">
                    <a href="/Teacher/Requests"><i class="fa-solid fa-file-alt"></i> Đơn từ</a>
                </li>
            }
        </ul>

        <div class="sidebar-bottom">
            <a href="/Notifications" class="btn-notification mb-0" style="position: relative;">
                <i class="fa-solid fa-bell" style="margin-right: 12px; font-size: 18px;"></i>
                Thông báo mới
                <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle p-2 bg-danger border border-light rounded-circle" style="display: none; margin-left: -15px; margin-top: 15px;">
                    <span class="visually-hidden">New alerts</span>
                </span>
            </a>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <div class="topbar-divider"></div>
            <div class="dropdown">
                <div class="d-flex align-items-center" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                    <div class="user-info">
                        <p class="user-name">@fullName</p>
                        <p class="user-role">@roleDisplay</p>
                    </div>
                    <div class="user-avatar">
                        <i class="fa-solid fa-person"></i>
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" style="border-radius: 8px; min-width: 260px;">
                    <li><div class="dropdown-header fw-bold text-dark fs-6 pb-0">@fullName</div></li>
                    <li><div class="dropdown-item-text text-muted pt-0" style="font-size: 13px;">@roleDisplay</div></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><div class="dropdown-item-text text-muted py-1 d-flex align-items-center" style="font-size: 13px;"><i class="fa-solid fa-envelope me-2 text-center" style="width: 20px;"></i> @email</div></li>
                    <li><div class="dropdown-item-text text-muted py-1 d-flex align-items-center" style="font-size: 13px;"><i class="fa-solid fa-phone me-2 text-center" style="width: 20px;"></i> @phone</div></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger fw-bold py-2" href="/Logout"><i class="fa-solid fa-sign-out-alt me-2"></i> Đăng xuất</a></li>
                </ul>
            </div>
        </div>
        
        <div class="content-body">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            try {
                const res = await fetch(`/api/web/notification?_t=${new Date().getTime()}`);
                if (res.ok) {
                    const notifs = await res.json();
                    const unread = notifs.filter(n => !n.isRead).length;
                    if (unread > 0) {
                        document.getElementById('notificationBadge').style.display = 'block';
                    }
                }
            } catch(e) {}
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
